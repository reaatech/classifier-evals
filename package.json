{
  "name": "classifier-evals",
  "version": "0.1.0",
  "description": "Offline classifier evaluation harness for intent classification systems with confusion matrices, LLM-as-judge, regression gates, and Phoenix/Langfuse exporters",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "classifier-evals": "dist/src/cli.js"
  },
  "files": [
    "dist/src/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "classifier",
    "evaluation",
    "intent-classification",
    "llm-judge",
    "ml-ops",
    "confusion-matrix",
    "regression-gates",
    "mcp",
    "phoenix",
    "langfuse"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage",
    "dev": "npm run build && node --enable-source-maps dist/src/cli.js",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/sdk-metrics": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "commander": "^12.1.0",
    "openai": "^4.70.0",
    "pino": "^9.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.5.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/classifier-evals.git"
  },
  "homepage": "https://github.com/reaatech/classifier-evals#readme",
  "bugs": {
    "url": "https://github.com/reaatech/classifier-evals/issues"
  }
}
