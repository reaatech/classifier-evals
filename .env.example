# =============================================
# classifier-evals Environment Configuration
# =============================================
# Copy this file to .env and fill in the values.
# Never commit .env files to version control.
# =============================================

# =============================================
# General Configuration
# =============================================
NODE_ENV=development

# =============================================
# OpenAI API (for LLM-as-Judge with GPT)
# =============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=

# =============================================
# Anthropic API (for LLM-as-Judge with Claude)
# =============================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_BASE_URL=

# =============================================
# LLM Judge Configuration
# =============================================
# Default judge model: gpt-4-turbo, claude-opus, etc.
JUDGE_MODEL=gpt-4-turbo
# Maximum budget for LLM judging per run (in USD)
JUDGE_BUDGET_LIMIT=50.00
# Maximum cost per sample (in USD)
JUDGE_MAX_COST_PER_SAMPLE=0.05
# Number of judges for consensus voting
JUDGE_CONSENSUS_COUNT=1
# Request timeout in milliseconds
JUDGE_TIMEOUT_MS=30000
# Number of retries for failed requests
JUDGE_RETRY_COUNT=3

# =============================================
# Observability
# =============================================
# OpenTelemetry Collector Endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Log Level: debug, info, warn, error
LOG_LEVEL=info

# =============================================
# Phoenix Exporter
# =============================================
PHOENIX_ENDPOINT=http://localhost:6006

# =============================================
# Langfuse Exporter
# =============================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# =============================================
# Gate Configuration
# =============================================
# Default gate thresholds
GATE_MIN_ACCURACY=0.85
GATE_MIN_F1_MACRO=0.80
